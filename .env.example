# Vercel Blob (Project → Storage → Blob → .env snippet)
BLOB_READ_WRITE_TOKEN=

# Upstash Redis / KV (Vercel integration or Upstash dashboard — paste real values in .env only)
KV_REST_API_READ_ONLY_TOKEN=
KV_REST_API_TOKEN=
KV_REST_API_URL=
KV_URL=
REDIS_URL=

# Single admin (bcrypt hash of password — never commit real secrets)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Min 16 chars, random
SESSION_SECRET=

# Optional: manual cron trigger Authorization: Bearer <CRON_SECRET>
# Vercel Cron also sends x-vercel-cron: 1 in production
CRON_SECRET=

# Optional page title in browser tab
PUBLIC_APP_NAME=Blob drop
